APP_NAME=Civil Monitoring Platform
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Seoul
HOST=0.0.0.0
PORT=8000

# JWT — generate with `openssl rand -hex 32`
SECRET_KEY=change_me_to_a_random_64_char_hex_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256
BCRYPT_ROUNDS=12

CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=civil_monitoring
POSTGRES_USER=civil
POSTGRES_PASSWORD=civil_pw
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=ingest
MQTT_PASSWORD=ingest_pw
MQTT_CLIENT_ID=civil-ingestion-1
MQTT_TOPIC_DATA=sites/+/sensors/+/data
MQTT_TOPIC_HEARTBEAT=sites/+/devices/+/heartbeat
MQTT_KEEPALIVE=60
MQTT_QOS=1

# Modbus polling — runs every hour at minute 0
MODBUS_POLL_CRON=0 * * * *
MODBUS_TIMEOUT_SECONDS=5
MODBUS_RETRIES=2

# Hourly export — runs every hour at minute 5
HOURLY_EXPORT_ENABLED=true
HOURLY_EXPORT_CRON=5 * * * *
EXPORT_DIR=/data/exports

# Health check
HEALTH_CHECK_CRON=*/5 * * * *
DEVICE_OFFLINE_THRESHOLD_MINUTES=15

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@civil-monitoring.local
SMTP_USE_TLS=true

# Webhooks (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
